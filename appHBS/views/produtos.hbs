<h1>Lista de Produtos</h1>

{{!-- Verifica se há produtos e renderiza a tabela --}}
{{#if produtos}}
  {{#if produtos.length}}
    <table border="1" cellpadding="10" cellspacing="0">
      <thead>
        <tr>
          <th>ID</th>
          <th>Nome</th>
          <th>Preço</th>
        </tr>
      </thead>
      <tbody>
        {{!-- Itera sobre cada produto --}}
        {{#each produtos}}
          <tr>
            <td>{{this.id}}</td>
            <td>{{this.nome}}</td>
            {{!-- Formata preço com símbolo de moeda brasileira --}}
            <td>R$ {{fixed this.preco 2}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p>Nenhum produto disponível.</p>
  {{/if}}
{{else}}
  <p>Nenhum produto disponível.</p>
{{/if}}
